# Suricata Custom Rules — SOC Lab 3
# File: /usr/local/etc/suricata/suricata_64296_em0/rules/custom.rules

# =============================================================================
# S1: Nmap Port Scan Detection
# MITRE ATT&CK: T1046 - Network Service Discovery
# Threshold: 20 SYN packets from same src in 10 seconds
# =============================================================================
alert tcp any any -> $HOME_NET any (msg:"SCAN Nmap Port Scan Detected"; flags:S; threshold:type threshold,track by_src,count 20,seconds 10; classtype:network-scan; sid:9000002; rev:1;)

# =============================================================================
# S2: Low and Slow Scan Detection
# MITRE ATT&CK: T1046 (Evasion variant)
# Threshold: 5 SYN packets from same src in 60 seconds
# Note: Intentionally low threshold to catch evasion attempts
# =============================================================================
alert tcp any any -> $HOME_NET any (msg:"SCAN Low and Slow Port Scan"; flags:S; threshold:type threshold,track by_src,count 5,seconds 60; classtype:network-scan; sid:9000003; rev:1;)

# =============================================================================
# S3: SSH Brute Force Detection
# MITRE ATT&CK: T1110 - Brute Force (T1110.001 SSH)
# Threshold: 5 connection attempts to port 22 in 60 seconds
# Priority 1: High severity - attempted admin privilege gain
# =============================================================================
alert tcp any any -> $HOME_NET 22 (msg:"ATTACK SSH Brute Force Detected"; flow:to_server; threshold:type threshold,track by_src,count 5,seconds 60; classtype:attempted-admin; sid:9000004; rev:1;)
